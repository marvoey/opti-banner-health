# Optimizely CMS SaaS — copy to .env and fill in real values (.env is gitignored).

OPTIMIZELY_DEFAULT_LOCALE=en

# Used by the @optimizely/cms-cli to push content types to your CMS instance.
# Create an API client in CMS admin -> Settings -> API Clients.
OPTIMIZELY_CMS_URL=https://your-instance.cms.optimizely.com/
OPTIMIZELY_CMS_CLIENT_ID=
OPTIMIZELY_CMS_CLIENT_SECRET=

# Used by the runtime (Next.js) to fetch content via Optimizely Graph.
# Found in the Graph admin. The gateway URL is optional — the SDK
# defaults to https://cg.optimizely.com/content/v2.
OPTIMIZELY_GRAPH_SINGLE_KEY=
OPTIMIZELY_GRAPH_GATEWAY=https://cg.optimizely.com/content/v2

# Shared secret appended to the preview URL registered in CMS so /api/draft
# can validate inbound preview requests. Also signs /cmp-preview tokens.
# Generate with: openssl rand -hex 32
OPTIMIZELY_PREVIEW_SECRET=

# Public (browser-side) CMS origin. Used by <LivePreviewScript> to load the
# communicationinjector.js script that bridges the CMS editor iframe to this
# app (fires optimizely:cms:contentSaved on save). Same value as
# OPTIMIZELY_CMS_URL above. NEXT_PUBLIC_ prefix exposes it to the client bundle.
NEXT_PUBLIC_OPTIMIZELY_CMS_URL=https://your-instance.cms.optimizely.com

# --- CMP preview bridge (lib/cmp) — see demo-notes/033-cmp-preview-bridge.md ---
# Mock/sandbox mode is ON by default; the whole flow runs with no live creds.
# Set CMP_MOCK=0 once a CSM/AE provisions the credentials below.
CMP_MOCK=1
# Default render source for generated preview URLs: `occ` (self-contained, HMAC
# Graph pull) or `cms` (content modelled in this instance).
CMP_PREVIEW_SOURCE=occ
# Absolute origin used to build preview URLs handed back to CMP.
CMP_APP_ORIGIN=http://localhost:3006
# Upper bound (ms) for the "wait for draft in Graph" poll.
CMP_PREVIEW_POLL_TIMEOUT_MS=15000

# CMP REST API (OAuth2 client credentials). Defaults target api.cmp.optimizely.com/v3.
CMP_API_BASE=https://api.cmp.optimizely.com/v3
CMP_OAUTH_TOKEN_URL=https://accounts.cmp.optimizely.com/o/oauth2/v1/token
CMP_CLIENT_ID=
CMP_CLIENT_SECRET=
# HMAC secret CMP signs its webhooks with (required when CMP_MOCK=0).
CMP_WEBHOOK_SECRET=
# Identifier recorded as the acknowledger of a preview request.
CMP_ACK_USER_ID=banner-preview-bridge

# Optimizely Graph draft reads via epi-hmac (the `occ` render source).
OPTIMIZELY_GRAPH_HMAC_ENDPOINT=https://cg.optimizely.com
OPTIMIZELY_GRAPH_HMAC_KEY=
OPTIMIZELY_GRAPH_HMAC_SECRET=
