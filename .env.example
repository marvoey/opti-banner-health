# Optimizely CMS SaaS — copy to .env and fill in real values (.env is gitignored).

# Default content locale configured in the CMS (used by proxy.ts for clean URLs).
OPTIMIZELY_DEFAULT_LOCALE=en

# CMS instance URL (no trailing slash). Used by the CLI and the preview communication injector.
OPTIMIZELY_CMS_URL=https://your-instance.cms.optimizely.com
# Public copy of the CMS URL if any client component needs it.
NEXT_PUBLIC_OPTIMIZELY_CMS_URL=https://your-instance.cms.optimizely.com

# CLI credentials (CMS → Settings → API Clients) — needed for `opti-cli config push`.
OPTIMIZELY_CMS_CLIENT_ID=
OPTIMIZELY_CMS_CLIENT_SECRET=

# Optimizely Graph delivery (CMS → Settings → API Keys → Render Content).
OPTIMIZELY_GRAPH_SINGLE_KEY=
OPTIMIZELY_GRAPH_GATEWAY=https://cg.optimizely.com/content/v2

# Optional shared secret to guard the /preview route.
OPTIMIZELY_PREVIEW_SECRET=
